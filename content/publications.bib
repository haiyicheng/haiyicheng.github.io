@unpublished{li2026internet,
  author = {Long Li and Haiyi Cheng and Guangzhao Jin and Rize Jing},
  title  = {Does Pressured Internet Use Promote Chinese Older Adults' Mental Health?},
  year   = {2026},
  note   = {Revise and Resubmit at *Depression and Anxiety*},
  abstract = {The rapid development of Internet technology and the swift digitization of public services may expose middle-aged and older adults to challenges of pressured Internet use. This study aimed to compare the relationships between pressured and voluntary Internet use and mental health among Chinese middle-aged and older adults, and to explore the mediating role of subjective age. The confirmatory latent class analysis was employed to identify pressured and voluntary Internet use patterns. Structural equation modeling was utilized to examine their differential associations with depressive symptoms and the mediating effects of subjective age. Among middle-aged and older Internet users, 27% engaged in pressured Internet use. Voluntary Internet use demonstrated significant effects on reducing depressive symptoms via lowering subjective age. Pressured Internet use showed no discernible effect on depressive symptoms compared to non-use. Therefore, supporting self-driven digital participation is crucial in addressing well-being disparities in the context of proliferating Internet services.}
}

@inproceedings{cheng2025education_health,
  author    = {Haiyi Cheng and Wendy Yiqing Chao},
  title     = {The Moderating Role of Early Life Family Environment on the Education-Health Relationship},
  booktitle = {Population Association of America 2025 Annual Meeting; American Sociological Association 2025 Annual Meeting},
  year      = {2025},
  abstract  = {This study examines how early life family environments moderate the relationship between educational attainment and cardiometabolic risk (CMR) across racial/ethnic groups in the United States. Using data from the National Longitudinal Study of Adolescent to Adult Health (Add Health), we focus on several key family factors: family cohesion, parental expectations for education, parenting style, parental education, parental income, and family structure. Our findings reveal that the association between educational attainment and CMR varies substantially by race/ethnicity and is significantly moderated by family environment. White respondents demonstrate robust health benefits from higher education regardless of family context, while Black respondents show significant health improvements from higher education only in specific family environments characterized by high cohesion, high educational expectations, and two-parent families. Counterintuitively, Black respondents from families with autonomic parenting styles, lower parental education, and lower parental income experience greater health benefits from higher education than those from more socioeconomically advantaged backgrounds. For US-Born Hispanics, education's health benefits are most pronounced in contexts of high parental income and expectations, while Foreign-Born Hispanics show more limited patterns of educational health benefits. These findings underscore the importance of family context in shaping health trajectories and highlight the need for targeted interventions to reduce racial health disparities that consider both educational attainment and family background.}
}

